generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  STUDENT
  ADMIN
}

enum DayOfWeek {
  MONDAY
  TUESDAY
  WEDNESDAY
  THURSDAY
  FRIDAY
  SATURDAY
  SUNDAY
}

enum SessionType {
  LECTURE
  LAB
  TUTORIAL
  SEMINAR
}

enum AttendanceStatus {
  PRESENT
  ABSENT
  CANCELLED
}

enum ResourceType {
  NOTE
  PYQ
  BOOK
  RESOURCE
}

enum FileKind {
  PDF
  DOC
  IMAGE
  LINK
  OTHER
}

enum AssignmentPriority {
  LOW
  MEDIUM
  HIGH
}

enum AssignmentStatus {
  PENDING
  IN_PROGRESS
  SUBMITTED
  COMPLETED
  OVERDUE
}

enum ForumCategory {
  GENERAL
  ACADEMICS
  CAREER
  EVENTS
  CONFESSIONS
  TECH
  OFF_TOPIC
}

enum ClubCategory {
  TECHNICAL
  CULTURAL
  SPORTS
  SOCIAL_SERVICE
  ARTS
  ENTREPRENEURSHIP
  OTHER
}

enum EventCategory {
  WORKSHOP
  SEMINAR
  FEST
  COMPETITION
  MEETUP
  OTHER
}

enum RsvpStatus {
  GOING
  INTERESTED
  NOT_GOING
}

enum ListingType {
  BUY_SELL
  LOST_FOUND
  ACADEMIC_ASSISTANCE
}

enum ListingCategory {
  // Buy & Sell
  BOOKS_STUDY_MATERIAL
  ELECTRONICS
  FURNITURE
  COSTUMES_ACCESSORIES
  BICYCLES_VEHICLES
  SPORTS_FITNESS
  OTHER_ITEMS

  // Lost & Found
  LOST_ITEM
  FOUND_ITEM

  // Academic Assistance (tutoring/mentoring only — never assignment outsourcing)
  TUTORING
  PROJECT_MENTORING
  CAD_GUIDANCE
  CODING_HELP
  RESUME_REVIEW
}

enum ListingCondition {
  NEW
  LIKE_NEW
  GOOD
  FAIR
  WORN
}

enum ListingStatus {
  ACTIVE
  RESERVED
  SOLD
  RESOLVED
  EXPIRED
}

// ---- Career Hub enums ----
enum InternshipMode {
  REMOTE
  ONSITE
  HYBRID
}

enum InternshipCategory {
  SOFTWARE_DEV
  DATA_SCIENCE
  DESIGN
  MARKETING
  FINANCE
  CORE_ENGINEERING
  RESEARCH
  OTHER
}

enum HackathonMode {
  REMOTE
  ONSITE
  HYBRID
}

enum CodingResourceCategory {
  DSA
  WEB_DEV
  SYSTEM_DESIGN
  COMPETITIVE_PROGRAMMING
  INTERVIEW_PREP
  LANGUAGES
  OTHER
}

enum CodingResourceDifficulty {
  BEGINNER
  INTERMEDIATE
  ADVANCED
}

enum ProgressStatus {
  NOT_STARTED
  IN_PROGRESS
  COMPLETED
}

// ---- AI Tools enums ----
enum AiConversationType {
  CHAT
  PDF_SUMMARIZER
  STUDY_PLANNER
  QUESTION_SOLVER
}

enum AiMessageRole {
  USER
  ASSISTANT
}

// ---- Admin Panel enum ----
enum AnnouncementPriority {
  LOW
  NORMAL
  HIGH
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String    @unique
  emailVerified DateTime?
  image         String?
  password      String?
  role          Role      @default(STUDENT)

  // Student profile fields (extendable in later prompts)
  collegeName   String?
  course        String?
  semester      Int?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  accounts             Account[]
  sessions             Session[]
  passwordResetTokens  PasswordResetToken[]
  subjects             Subject[]
  timetableSlots       TimetableSlot[]
  attendanceRecords    AttendanceRecord[]
  resources            Resource[]
  bookmarks            Bookmark[]
  ratings              Rating[]
  assignments          Assignment[]
  forumPosts           ForumPost[]
  postComments         PostComment[]
  postLikes            PostLike[]
  commentLikes         CommentLike[]
  postBookmarks        PostBookmark[]
  seniorGuidancePosts  SeniorGuidance[]
  clubMemberships      ClubMembership[]
  eventRsvps           EventRsvp[]
  marketplaceListings  MarketplaceListing[]
  internshipBookmarks  InternshipBookmark[]
  hackathonBookmarks   HackathonBookmark[]
  codingResourceBookmarks CodingResourceBookmark[]
  postedInternships    Internship[]
  postedHackathons     Hackathon[]
  addedCodingResources CodingResource[]
  codingProgress       CodingProgress[]
  resumes              Resume[]
  aiConversations      AiConversation[]
  announcements        Announcement[]

  @@map("users")
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@map("accounts")
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
  @@map("verification_tokens")
}

model PasswordResetToken {
  id      String   @id @default(cuid())
  token   String   @unique
  userId  String
  expires DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("password_reset_tokens")
}

model Subject {
  id             String   @id @default(cuid())
  userId         String
  name           String
  code           String?
  color          String   @default("#6366f1")
  targetPercent  Int      @default(75)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  user              User                @relation(fields: [userId], references: [id], onDelete: Cascade)
  timetableSlots    TimetableSlot[]
  attendanceRecords AttendanceRecord[]

  @@index([userId])
  @@map("subjects")
}

model TimetableSlot {
  id        String      @id @default(cuid())
  userId    String
  subjectId String
  dayOfWeek DayOfWeek
  startTime String // "09:00"
  endTime   String // "10:00"
  room      String?
  type      SessionType @default(LECTURE)
  createdAt DateTime    @default(now())
  updatedAt DateTime    @updatedAt

  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  subject Subject @relation(fields: [subjectId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([subjectId])
  @@map("timetable_slots")
}

model AttendanceRecord {
  id        String            @id @default(cuid())
  userId    String
  subjectId String
  date      DateTime          @db.Date
  status    AttendanceStatus
  note      String?
  createdAt DateTime          @default(now())
  updatedAt DateTime          @updatedAt

  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  subject Subject @relation(fields: [subjectId], references: [id], onDelete: Cascade)

  @@unique([subjectId, date])
  @@index([userId])
  @@index([subjectId])
  @@map("attendance_records")
}

// ---- Academic Hub ----
// Unified model backing Notes, Previous Year Papers, Books, and general
// Resources. `type` distinguishes which section a given upload belongs to.
model Resource {
  id           String       @id @default(cuid())
  uploaderId   String
  type         ResourceType
  title        String
  description  String?
  subjectName  String // free-text subject/course label (not FK'd to Subject,
  // since resources can be shared across users/subjects not yet tracked)
  semester     Int?
  author       String? // used for Books ("by <author>")
  year         Int? // used for PYQs (exam year)
  fileUrl      String // link to the uploaded file (or external resource link)
  fileKind     FileKind     @default(PDF)
  fileSizeKb   Int?
  downloadCount Int         @default(0)
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt

  uploader  User       @relation(fields: [uploaderId], references: [id], onDelete: Cascade)
  bookmarks Bookmark[]
  ratings   Rating[]

  @@index([uploaderId])
  @@index([type])
  @@index([subjectName])
  @@map("resources")
}

model Bookmark {
  id         String   @id @default(cuid())
  userId     String
  resourceId String
  createdAt  DateTime @default(now())

  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  resource Resource @relation(fields: [resourceId], references: [id], onDelete: Cascade)

  @@unique([userId, resourceId])
  @@index([resourceId])
  @@map("bookmarks")
}

model Rating {
  id         String   @id @default(cuid())
  userId     String
  resourceId String
  value      Int // 1-5
  comment    String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  resource Resource @relation(fields: [resourceId], references: [id], onDelete: Cascade)

  @@unique([userId, resourceId])
  @@index([resourceId])
  @@map("ratings")
}

// ---- Assignment Module ----
model Assignment {
  id          String             @id @default(cuid())
  userId      String
  title       String
  description String?
  subjectName String // free-text, same convention as Resource.subjectName
  dueDate     DateTime
  priority    AssignmentPriority @default(MEDIUM)
  status      AssignmentStatus   @default(PENDING)
  reminderAt  DateTime? // when to notify the user before the due date
  submittedAt DateTime?
  createdAt   DateTime           @default(now())
  updatedAt   DateTime           @updatedAt

  user        User                   @relation(fields: [userId], references: [id], onDelete: Cascade)
  attachments AssignmentAttachment[]

  @@index([userId])
  @@index([dueDate])
  @@index([status])
  @@map("assignments")
}

model AssignmentAttachment {
  id           String   @id @default(cuid())
  assignmentId String
  name         String
  fileUrl      String
  fileKind     FileKind @default(PDF)
  fileSizeKb   Int?
  createdAt    DateTime @default(now())

  assignment Assignment @relation(fields: [assignmentId], references: [id], onDelete: Cascade)

  @@index([assignmentId])
  @@map("assignment_attachments")
}

// ---- Community Module ----
// Discussion Forum: posts optionally authored anonymously. `authorId` still
// records the real user (for moderation/ownership), while `isAnonymous`
// controls whether the UI displays the author's name or "Anonymous".
model ForumPost {
  id          String        @id @default(cuid())
  authorId    String
  category    ForumCategory @default(GENERAL)
  title       String
  body        String
  isAnonymous Boolean       @default(false)
  isPinned    Boolean       @default(false)
  viewCount   Int           @default(0)
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  author    User           @relation(fields: [authorId], references: [id], onDelete: Cascade)
  comments  PostComment[]
  likes     PostLike[]
  bookmarks PostBookmark[]

  @@index([authorId])
  @@index([category])
  @@map("forum_posts")
}

// Comments and Replies share one model: a reply is simply a comment whose
// `parentId` points at another comment. Top-level comments have parentId null.
model PostComment {
  id          String   @id @default(cuid())
  postId      String
  authorId    String
  parentId    String?
  body        String
  isAnonymous Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  post    ForumPost     @relation(fields: [postId], references: [id], onDelete: Cascade)
  author  User          @relation(fields: [authorId], references: [id], onDelete: Cascade)
  parent  PostComment?  @relation("CommentReplies", fields: [parentId], references: [id], onDelete: Cascade)
  replies PostComment[] @relation("CommentReplies")
  likes   CommentLike[]

  @@index([postId])
  @@index([parentId])
  @@index([authorId])
  @@map("post_comments")
}

model PostLike {
  id        String   @id @default(cuid())
  userId    String
  postId    String
  createdAt DateTime @default(now())

  user User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  post ForumPost @relation(fields: [postId], references: [id], onDelete: Cascade)

  @@unique([userId, postId])
  @@index([postId])
  @@map("post_likes")
}

model CommentLike {
  id        String   @id @default(cuid())
  userId    String
  commentId String
  createdAt DateTime @default(now())

  user    User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  comment PostComment @relation(fields: [commentId], references: [id], onDelete: Cascade)

  @@unique([userId, commentId])
  @@index([commentId])
  @@map("comment_likes")
}

// Separate from the Academic Hub's `Bookmark` model (which is scoped to
// Resources) so the Community module doesn't touch previously built models.
model PostBookmark {
  id        String   @id @default(cuid())
  userId    String
  postId    String
  createdAt DateTime @default(now())

  user User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  post ForumPost @relation(fields: [postId], references: [id], onDelete: Cascade)

  @@unique([userId, postId])
  @@index([postId])
  @@map("post_bookmarks")
}

// Senior Guidance: a distinct Q&A-style section where senior students answer
// questions from juniors. Modeled separately from ForumPost since guidance
// posts carry different metadata (tags, "answered" state) than open discussion.
model SeniorGuidance {
  id          String   @id @default(cuid())
  authorId    String
  title       String
  body        String
  tags        String[] @default([])
  isAnonymous Boolean  @default(false)
  isAnswered  Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  author User @relation(fields: [authorId], references: [id], onDelete: Cascade)

  @@index([authorId])
  @@map("senior_guidance_posts")
}

model Club {
  id          String       @id @default(cuid())
  name        String
  description String
  category    ClubCategory @default(OTHER)
  logoColor   String       @default("#6366f1")
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  memberships ClubMembership[]
  events      Event[]

  @@map("clubs")
}

model ClubMembership {
  id        String   @id @default(cuid())
  clubId    String
  userId    String
  joinedAt  DateTime @default(now())

  club Club @relation(fields: [clubId], references: [id], onDelete: Cascade)
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([clubId, userId])
  @@index([userId])
  @@map("club_memberships")
}

model Event {
  id          String        @id @default(cuid())
  clubId      String?
  organizerId String
  title       String
  description String
  category    EventCategory @default(OTHER)
  location    String?
  startsAt    DateTime
  endsAt      DateTime?
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  club   Club?       @relation(fields: [clubId], references: [id], onDelete: SetNull)
  rsvps  EventRsvp[]

  @@index([clubId])
  @@index([startsAt])
  @@map("events")
}

model EventRsvp {
  id        String     @id @default(cuid())
  eventId   String
  userId    String
  status    RsvpStatus @default(INTERESTED)
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt

  event Event @relation(fields: [eventId], references: [id], onDelete: Cascade)
  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([eventId, userId])
  @@index([eventId])
  @@map("event_rsvps")
}

// ---- Marketplace Module ----
// One unified listing model backs Buy & Sell, Lost & Found, and Academic
// Assistance. `listingType` distinguishes the section; type-specific fields
// (price/condition for Buy & Sell, lost/found flag for Lost & Found, skill
// area for Academic Assistance) are optional so one model serves all three.
//
// Academic Assistance listings are intentionally scoped to tutoring, project
// mentoring, CAD guidance, coding help, and resume reviews via the
// ListingCategory enum — there is no "assignment help" category, by design,
// to avoid enabling assignment outsourcing.
model MarketplaceListing {
  id          String            @id @default(cuid())
  sellerId    String
  listingType ListingType
  category    ListingCategory
  title       String
  description String
  price        Float? // null/0 = free or not applicable (e.g. Lost & Found, some tutoring offers)
  isNegotiable Boolean           @default(false)
  condition    ListingCondition? // Buy & Sell only
  location     String? // where to meet / where item was lost or found
  contactPhone String? // optional, in addition to the seller's account email
  status      ListingStatus     @default(ACTIVE)
  viewCount   Int               @default(0)
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt

  seller User            @relation(fields: [sellerId], references: [id], onDelete: Cascade)
  images ListingImage[]

  @@index([sellerId])
  @@index([listingType])
  @@index([category])
  @@index([status])
  @@map("marketplace_listings")
}

model ListingImage {
  id        String   @id @default(cuid())
  listingId String
  url       String
  position  Int      @default(0)
  createdAt DateTime @default(now())

  listing MarketplaceListing @relation(fields: [listingId], references: [id], onDelete: Cascade)

  @@index([listingId])
  @@map("listing_images")
}

// ---- Career Hub Module ----
model Internship {
  id             String             @id @default(cuid())
  postedById     String
  title          String
  company        String
  category       InternshipCategory @default(OTHER)
  mode           InternshipMode     @default(ONSITE)
  location       String?
  stipend        String? // free-text, e.g. "₹15,000/month" — stipends vary too much to model as a strict number
  durationWeeks  Int?
  applyUrl       String
  description    String
  deadline       DateTime?
  createdAt      DateTime           @default(now())
  updatedAt      DateTime           @updatedAt

  postedBy  User                 @relation(fields: [postedById], references: [id], onDelete: Cascade)
  bookmarks InternshipBookmark[]

  @@index([postedById])
  @@index([category])
  @@map("internships")
}

model InternshipBookmark {
  id           String   @id @default(cuid())
  userId       String
  internshipId String
  createdAt    DateTime @default(now())

  user       User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  internship Internship @relation(fields: [internshipId], references: [id], onDelete: Cascade)

  @@unique([userId, internshipId])
  @@index([internshipId])
  @@map("internship_bookmarks")
}

model Hackathon {
  id          String        @id @default(cuid())
  postedById  String
  title       String
  organizer   String
  mode        HackathonMode @default(ONSITE)
  location    String?
  prizePool   String? // free-text, e.g. "₹50,000 + goodies"
  registerUrl String
  description String
  startsAt    DateTime
  endsAt      DateTime?
  regDeadline DateTime?
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  postedBy  User                @relation(fields: [postedById], references: [id], onDelete: Cascade)
  bookmarks HackathonBookmark[]

  @@index([postedById])
  @@index([startsAt])
  @@map("hackathons")
}

model HackathonBookmark {
  id          String   @id @default(cuid())
  userId      String
  hackathonId String
  createdAt   DateTime @default(now())

  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  hackathon Hackathon @relation(fields: [hackathonId], references: [id], onDelete: Cascade)

  @@unique([userId, hackathonId])
  @@index([hackathonId])
  @@map("hackathon_bookmarks")
}

// Curated coding practice resources (roadmaps, problem sets, courses, etc.)
// Progress tracking is modeled per-user via CodingProgress, separate from the
// resource itself, so the same resource can show a different completion
// status for each student.
model CodingResource {
  id          String                    @id @default(cuid())
  addedById   String
  title       String
  provider    String? // e.g. "LeetCode", "freeCodeCamp"
  category    CodingResourceCategory    @default(OTHER)
  difficulty  CodingResourceDifficulty  @default(BEGINNER)
  url         String
  description String
  createdAt   DateTime                  @default(now())
  updatedAt   DateTime                  @updatedAt

  addedBy   User                      @relation(fields: [addedById], references: [id], onDelete: Cascade)
  bookmarks CodingResourceBookmark[]
  progress  CodingProgress[]

  @@index([addedById])
  @@index([category])
  @@map("coding_resources")
}

model CodingResourceBookmark {
  id         String   @id @default(cuid())
  userId     String
  resourceId String
  createdAt  DateTime @default(now())

  user     User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  resource CodingResource @relation(fields: [resourceId], references: [id], onDelete: Cascade)

  @@unique([userId, resourceId])
  @@index([resourceId])
  @@map("coding_resource_bookmarks")
}

model CodingProgress {
  id         String         @id @default(cuid())
  userId     String
  resourceId String
  status     ProgressStatus @default(NOT_STARTED)
  updatedAt  DateTime       @updatedAt
  createdAt  DateTime       @default(now())

  user     User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  resource CodingResource @relation(fields: [resourceId], references: [id], onDelete: Cascade)

  @@unique([userId, resourceId])
  @@index([resourceId])
  @@map("coding_progress")
}

// Resume Builder: structured resume content stored as JSON per section, kept
// flexible so the builder UI can evolve sections without schema migrations.
// PDF export happens client-side from this data (see resume PDF export util).
model Resume {
  id        String   @id @default(cuid())
  userId    String
  title     String   @default("My Resume")
  fullName  String?
  email     String?
  phone     String?
  location  String?
  summary   String?
  education Json // array of { school, degree, startYear, endYear, notes }
  experience Json // array of { company, role, startDate, endDate, description }
  projects  Json // array of { name, description, link, techStack }
  skills    Json // array of strings
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("resumes")
}

// ---- AI Tools Module ----
// One conversation model backs AI Chat, PDF Summarizer, Study Planner, and
// Question Solver — distinguished by `type` — so all four can share the same
// reusable chat UI and message history storage. The Attendance Predictor is
// deliberately NOT modeled here: it's a deterministic calculation over real
// AttendanceRecord/Subject data (see /api/ai/attendance-predictor), not a
// free-form chat, so it doesn't need conversation storage.
model AiConversation {
  id        String             @id @default(cuid())
  userId    String
  type      AiConversationType
  title     String             @default("New conversation")
  // For PDF_SUMMARIZER: original filename of the summarized PDF, if any.
  sourceFileName String?
  createdAt DateTime           @default(now())
  updatedAt DateTime           @updatedAt

  user     User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  messages AiMessage[]

  @@index([userId])
  @@index([type])
  @@map("ai_conversations")
}

model AiMessage {
  id             String         @id @default(cuid())
  conversationId String
  role           AiMessageRole
  content        String
  createdAt      DateTime       @default(now())

  conversation AiConversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  @@index([conversationId])
  @@map("ai_messages")
}

// ---- Admin Panel Module ----
// Platform-wide announcements posted by admins, visible to all students on
// their dashboard. Kept separate from the Community module's ForumPost since
// announcements are admin-authored broadcast messages, not discussion posts.
model Announcement {
  id        String               @id @default(cuid())
  authorId  String
  title     String
  body      String
  priority  AnnouncementPriority @default(NORMAL)
  isPinned  Boolean              @default(false)
  createdAt DateTime             @default(now())
  updatedAt DateTime             @updatedAt

  author User @relation(fields: [authorId], references: [id], onDelete: Cascade)

  @@index([authorId])
  @@map("announcements")
}
